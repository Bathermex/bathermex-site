---
interface Props { title?: string; text?: string; }
const {
  title = "Un projet de climatisation tertiaire ?",
  text = "Parlons de votre site et de vos besoins. Étude et chiffrage sans engagement.",
} = Astro.props;
---

<section class="bg-petrol text-fog">
  <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-5 py-16 md:flex-row md:items-center md:justify-between">
    <div>
      <div class="copper-rule mb-5"></div>
      <h2 class="max-w-xl text-2xl font-semibold text-white md:text-3xl">{title}</h2>
      <p class="mt-3 max-w-xl text-fog/80">{text}</p>
    </div>
    <a href="/contact" class="btn btn-light shrink-0">Demander un devis</a>
  </div>
</section>
