---
// ============================================================
// /solutions-cvc — S1 (Lot S). Page "hors menu" (nav ajoutée en S3).
// SOURCES :
//   ♻️ offre  = carte service "installation-vrv-drv" (export content.ts, texte EXACT prod)
//   ♻️ FAQ    = question "Quelle différence entre VRV et DRV ?" (export faq, texte EXACT)
//   ✏️ "comment on travaille" = volet étude→pose→MES RECRÉÉ (divergence D2 : n'existe
//        plus en ligne, la méthode prod est 100% maintenance). Base : historique git.
//        → relecture Brice attendue.
// ============================================================
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
import { services, faq, realisations } from "../data/content";

// FAQPage schema — reflète la FAQ visible


const installation = services.filter((s) => s.slug === "installation-vrv-drv");
const faqCvc = [
  ...faq.filter((f) => f.q.startsWith("Quelle différence")),
  {
    q: "Faut-il prévoir la maintenance dès l'installation ?",
    r: "C'est la meilleure approche. Une installation VRV / DRV neuve garde ses performances si elle est entretenue dès la première année : contrôles, nettoyages, suivi des charges de fluide. Nous proposons un contrat de maintenance en continuité de la pose — c'est aussi ce qui garantit le meilleur suivi, puisque votre parc est déjà documenté par nos équipes.",
  },
  {
    q: "L'étude est-elle réalisée avant le devis ?",
    r: "Oui, systématiquement. La visite technique et le bilan des besoins précèdent tout chiffrage : c'est ce qui permet un dimensionnement juste — ni sous-dimensionné (confort dégradé), ni surdimensionné (surcoût à l'achat et à l'usage).",
  },
  {
    q: "Intervenez-vous en copropriété ou en logement collectif ?",
    r: "Oui. Nous avons notamment réalisé la réfection complète de l'installation d'un immeuble de 45 logements sociaux (R+6) à Aix-en-Provence : production et distribution en chaufferie. Nous travaillons avec les syndics, copropriétés et bailleurs sociaux, en PACA et en Île-de-France.",
  },
];
const realisationsReelles = realisations.filter((r) => !r.placeholder);
const domaines = ["Bureaux & tertiaire", "Commerces", "Hôtellerie-restauration", "Santé / ERP"];
const faqSchemaCvc = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqCvc.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.r },
  })),
};

// ✏️ À RECRÉER (D2) — volet installation, relecture Brice
const methodeInstallation = [
  { n: "01", titre: "Étude", texte: "Visite technique, bilan des besoins et dimensionnement de l'installation." },
  { n: "02", titre: "Devis", texte: "Proposition chiffrée détaillée, options claires, sans engagement." },
  { n: "03", titre: "Pose", texte: "Installation par nos équipes, sur nos deux implantations (Marseille / Paris)." },
  { n: "04", titre: "Mise en service", texte: "Réglages, contrôles, remise en main et documentation de l'installation." },
];
---

<Base
  title="Installation climatisation VRV/DRV · Marseille & Paris"
  description="Étude, pose et mise en service de climatisation VRV/DRV pour bureaux, commerces, hôtels et ERP à Marseille, en PACA et en Île-de-France. Devis rapide."
>
  <PageHero
    image="/photos/hero-cvc.webp"
    imageAlt="Réseau de gaines de ventilation en bâtiment tertiaire — installation CVC VRV/DRV"
    eyebrow="Solutions CVC"
    title="Installation de climatisation VRV/DRV tertiaire à Marseille et en Île-de-France"
    intro="Remplacement, amélioration et installation d'équipements — en complément du contrat ou en projet dédié."
  />

  <!-- L'offre (♻️ texte exact du service installation) -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="space-y-5">
      {installation.map((s) => (
        <article id={s.slug} class="card grid gap-6 p-8 md:grid-cols-[auto_1fr] md:gap-10">
          <div class="font-display text-3xl font-semibold text-copper md:pt-1">01</div>
          <div>
            <h2 class="font-display text-2xl font-semibold text-ink">{s.titre}</h2>
            <p class="mt-2 text-lg text-slate">{s.accroche}</p>
            <p class="mt-4 max-w-3xl leading-relaxed text-slate">{s.detail}</p>
            <ul class="mt-5 flex flex-wrap gap-2">
              {s.points.map((p) => (
                <li class="rounded-full border border-mist bg-fog px-3 py-1 text-sm text-slate">{p}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Pourquoi le VRV/DRV — Lot SEO item 3 -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="copper-rule mb-5"></div>
      <h2 class="max-w-3xl text-3xl font-semibold text-ink">Pourquoi le VRV / DRV pour un bâtiment tertiaire</h2>
      <p class="mt-4 max-w-3xl leading-relaxed text-slate">
        La technologie VRV / DRV (débit de réfrigérant variable) module en permanence la puissance délivrée selon les besoins réels de chaque zone du bâtiment. Concrètement : des bureaux orientés sud rafraîchis pendant que des salles de réunion côté nord sont chauffées, à partir de la même installation.
      </p>
      <div class="mt-9 grid gap-8 md:grid-cols-3">
        <div>
          <h3 class="font-display text-lg font-semibold text-ink">Zonage indépendant</h3>
          <p class="mt-2 leading-relaxed text-slate">Chaque zone est pilotée séparément : température, horaires, priorités. Adapté aux plateaux de bureaux, commerces, hôtels et établissements de santé où les usages diffèrent d'un espace à l'autre.</p>
        </div>
        <div>
          <h3 class="font-display text-lg font-semibold text-ink">Sobriété à l'usage</h3>
          <p class="mt-2 leading-relaxed text-slate">La modulation du débit évite les cycles marche/arrêt permanents : l'installation ne délivre que la puissance nécessaire, au moment où elle est nécessaire.</p>
        </div>
        <div>
          <h3 class="font-display text-lg font-semibold text-ink">Discrétion et intégration</h3>
          <p class="mt-2 leading-relaxed text-slate">Unités intérieures compactes (cassettes, gainables, consoles) qui s'intègrent aux faux plafonds et aux contraintes architecturales des sites tertiaires occupés.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bandeau photo -->
  <section class="mx-auto max-w-6xl px-5 pb-4">
    <figure>
      <img src="/photos/inpage-cvc.webp" alt="Cassette de climatisation encastrée en faux-plafond avec gaines — installation VRV/DRV" width="1200" height="520" loading="lazy" class="aspect-[16/7] w-full rounded-xl object-cover shadow-sm" />
      <figcaption class="mt-3 text-center text-sm text-slate">Cassette de climatisation encastrée en faux-plafond — installation VRV/DRV tertiaire.</figcaption>
    </figure>
  </section>

  <!-- Pour qui (décision E actée) -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Pour qui</h2>
      <ul class="mt-6 flex flex-wrap gap-2">
        {domaines.map((d) => (
          <li class="rounded-full border border-mist bg-fog px-4 py-1.5 text-sm text-slate">{d}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Schéma pédagogique CVC (fourni par Brice, droits confirmés) — centré, taille native (549px) pour rester net -->
  <section class="mx-auto max-w-6xl px-5 pt-4 pb-12">
    <figure class="mx-auto max-w-2xl">
      <img src="/photos/schema-cvc.webp" alt="Schéma d'un système CVC : chauffage (chaudière, pompe à chaleur), ventilation (VMC, filtre à air, unité de traitement d'air) et climatisation (groupe froid, climatiseur split)" width="549" height="364" loading="lazy" class="mx-auto w-full rounded-xl border border-mist bg-white p-3 shadow-sm" />
      <figcaption class="mt-3 text-center text-sm text-slate">Un système CVC réunit chauffage, ventilation et climatisation autour d'une unité de traitement d'air.</figcaption>
    </figure>
  </section>

  <!-- Comment on travaille (✏️ recréé D2) -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="copper-rule mb-5"></div>
    <h2 class="max-w-xl text-3xl font-semibold text-ink">De l'étude à la mise en service</h2>
    <p class="mt-3 max-w-2xl text-slate">Un interlocuteur unique, de la première visite au réglage final.</p>
    <ol class="mt-12 grid gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {methodeInstallation.map((m) => (
        <li class="relative pr-6">
          <span class="font-display text-sm font-semibold text-copper">{m.n}</span>
          <h3 class="mt-2 font-display text-lg font-semibold text-ink">{m.titre}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate">{m.texte}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- Réalisations liées : conditionnel -->
  {realisationsReelles.length > 0 && (
    <section class="bg-paper">
      <div class="mx-auto max-w-6xl px-5 py-20">
        <div class="copper-rule mb-5"></div>
        <h2 class="text-3xl font-semibold text-ink">Réalisations liées</h2>
        <div class="mt-9 grid gap-5 md:grid-cols-3">
          {realisationsReelles.map((r) => (
            <article class="card overflow-hidden">
              {r.image && (
                <img src={r.image} alt={`${r.titre} — ${r.typologie}`} width="800" height="600" loading="lazy" class="aspect-[4/3] w-full object-cover" />
              )}
              <div class="p-6">
                <span class="eyebrow text-[0.7rem]">{r.typologie}</span>
                <h3 class="mt-2 font-display text-lg font-semibold text-ink">{r.titre}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate">{r.contexte}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ (♻️ Q1 exacte) -->
  {faqCvc.length > 0 && (
    <section class="mx-auto max-w-4xl px-5 py-16">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Questions fréquentes</h2>
      <div class="mt-8 divide-y divide-mist border-y border-mist">
        {faqCvc.map((f) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-medium text-ink">
              {f.q}
              <span class="text-copper transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-3 leading-relaxed text-slate">{f.r}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- Où nous intervenons — Lot SEO item 3 (aligné zones fiche Google) -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Où nous intervenons</h2>
      <p class="mt-4 max-w-3xl leading-relaxed text-slate">
        Nos équipes d'installation interviennent depuis Allauch sur Marseille, Aubagne, Aix-en-Provence, Marignane, Salon-de-Provence et l'ensemble des Bouches-du-Rhône et de la région PACA, et depuis notre implantation francilienne sur Paris et l'Île-de-France.
      </p>
      <p class="mt-3 max-w-3xl leading-relaxed text-slate">
        Après la mise en service, la continuité est assurée par nos <a href="/maintenance/" class="font-semibold text-copper hover:underline">contrats de maintenance</a> et, pour le pilotage à distance, par nos <a href="/solutions-gtb/" class="font-semibold text-copper hover:underline">solutions GTB</a>.
      </p>
    </div>
  </section>

  <CTA title="Un projet d'installation ?" text="Décrivez-nous votre site : nous revenons vers vous avec une étude et un chiffrage adaptés." />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchemaCvc)} />
</Base>
