---
// ============================================================
// /maintenance — S1 (Lot S). Page "hors menu" (nav ajoutée en S3).
// CONTENU 100% ♻️ REPRIS DE LA PROD (aucun texte inventé) :
//   hero  = hero + eyebrow de l'ancienne home pivot
//   offre = cartes services "maintenance" + "sav-depannage" (exports content.ts)
//   méthode = "Un parc suivi toute l'année" (export methode, 100% maintenance)
//   FAQ   = question "Proposez-vous des contrats de maintenance ?" (export faq)
// ============================================================
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
import { services, methode, faq, realisations, realisationsMaintenance, heroImages } from "../data/content";
import { site } from "../data/site";

const offre = services.filter((s) => ["maintenance", "sav-depannage"].includes(s.slug));
const faqMaintenance = faq.filter((f) => f.q.startsWith("Proposez-vous"));
const realisationsReelles = realisations.filter((r) => !r.placeholder);
const domaines = ["Bureaux & tertiaire", "Commerces", "Hôtellerie-restauration", "Santé / ERP"];
---

<Base
  title="Maintenance climatisation tertiaire PACA"
  description="Contrats de maintenance annuels, entretien préventif et dépannage de climatisation tertiaire en PACA et Île-de-France. Un parc suivi toute l'année."
>
  <PageHero
    image="/photos/hero-maintenance.webp"
    imageAlt="Technicien Bathermex en intervention de maintenance de climatisation sur toiture"
    eyebrow="Maintenance CVC · Contrats annuels · Préventif & curatif · PACA & Île-de-France"
    title="Maintenance de climatisation tertiaire : contrats annuels, préventif et dépannage"
    intro={site.tagline}
  />

  <!-- L'offre -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="space-y-5">
      {offre.map((s, i) => (
        <article id={s.slug} class="card grid gap-6 p-8 md:grid-cols-[auto_1fr] md:gap-10">
          <div class="font-display text-3xl font-semibold text-copper md:pt-1">{String(i + 1).padStart(2, "0")}</div>
          <div>
            <h2 class="font-display text-2xl font-semibold text-ink">{s.titre}</h2>
            <p class="mt-2 text-lg text-slate">{s.accroche}</p>
            <p class="mt-4 max-w-3xl leading-relaxed text-slate">{s.detail}</p>
            <ul class="mt-5 flex flex-wrap gap-2">
              {s.points.map((p) => (
                <li class="rounded-full border border-mist bg-fog px-3 py-1 text-sm text-slate">{p}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Bandeau photo -->
  <section class="mx-auto max-w-6xl px-5 pb-4">
    <figure>
      <img src="/photos/inpage-maintenance.webp" alt="Contrôle avec manifold sur une installation de climatisation — maintenance CVC" width="1200" height="520" loading="lazy" class="aspect-[16/7] w-full rounded-xl object-cover shadow-sm" />
      <figcaption class="mt-3 text-center text-sm text-slate">Contrôle des pressions au manifold lors d'une intervention de maintenance.</figcaption>
    </figure>
  </section>

  <!-- Pour qui (décision E actée) -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Pour qui</h2>
      <ul class="mt-6 flex flex-wrap gap-2">
        {domaines.map((d) => (
          <li class="rounded-full border border-mist bg-fog px-4 py-1.5 text-sm text-slate">{d}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Comment on travaille : méthode "Un parc suivi toute l'année" (♻️) -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="copper-rule mb-5"></div>
    <h2 class="max-w-xl text-3xl font-semibold text-ink">Un parc suivi toute l'année</h2>
    <p class="mt-3 max-w-2xl text-slate">Une méthode continue : état des lieux, contrat adapté, entretien planifié et dépannage — que l'on ait installé votre parc ou non.</p>
    <ol class="mt-12 grid gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {methode.map((m) => (
        <li class="relative pr-6">
          <span class="font-display text-sm font-semibold text-copper">{m.n}</span>
          <h3 class="mt-2 font-display text-lg font-semibold text-ink">{m.titre}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate">{m.texte}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- Réalisations liées : interventions de maintenance (photos réelles) -->
  {realisationsMaintenance.length > 0 && (
    <section class="bg-paper">
      <div class="mx-auto max-w-6xl px-5 py-20">
        <div class="copper-rule mb-5"></div>
        <h2 class="text-3xl font-semibold text-ink">Nos interventions de maintenance</h2>
        <div class="mt-9 grid gap-5 sm:grid-cols-2">
          {realisationsMaintenance.map((r) => (
            <article class="card overflow-hidden">
              {r.image && (
                <img src={r.image} alt={`${r.titre} — ${r.typologie}`} width="800" height="600" loading="lazy" class="aspect-[4/3] w-full object-cover" />
              )}
              <div class="p-6">
                <span class="eyebrow text-[0.7rem]">{r.typologie}</span>
                <h3 class="mt-2 font-display text-lg font-semibold text-ink">{r.titre}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate">{r.contexte}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faqMaintenance.length > 0 && (
    <section class="mx-auto max-w-4xl px-5 py-16">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Questions fréquentes</h2>
      <div class="mt-8 divide-y divide-mist border-y border-mist">
        {faqMaintenance.map((f) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-medium text-ink">
              {f.q}
              <span class="text-copper transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-3 leading-relaxed text-slate">{f.r}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <CTA title="Un contrat, une panne ?" text="Décrivez-nous votre parc : nous revenons vers vous avec une formule de maintenance adaptée." />
</Base>
