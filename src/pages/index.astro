---
// ============================================================
// / — HOME PORTAIL (S2). Remplace l'ancienne home pivot maintenance,
// dont le contenu vit désormais sur /maintenance.
// Sources : ✏️ hero/société/CTA (à valider direction) · ♻️ apercuAccueil ·
//           ✅ décision E (domaines) + décision F (6 logos).
// ============================================================
import Base from "../layouts/Base.astro";
import CTA from "../components/CTA.astro";
import { apercuAccueil, heroImages } from "../data/content";

// ✅ décision F — 6 logos clients (accords archivés Brice). Section masquée si vide.
const logosClients = [
  { src: "/logos/bnp-paribas-logo.svg", alt: "BNP Paribas" },
  { src: "/logos/clinique-juge-logo.svg", alt: "Clinique Juge" },
  { src: "/logos/la-poste-logo.svg", alt: "La Poste" },
  { src: "/logos/maif-logo.svg", alt: "MAIF" },
  { src: "/logos/monaco-marine-logo.svg", alt: "Monaco Marine" },
  { src: "/logos/thales-logo.svg", alt: "Thales" },
];

const solutions = [
  { href: "/solutions-cvc", titre: "Solutions CVC", texte: "Installation VRV/DRV, chauffage et ventilation pour le tertiaire." },
  { href: "/solutions-gtb", titre: "Solutions GTB", texte: "Supervision à distance, télémaintenance et intégration de vos équipements." },
  { href: "/maintenance", titre: "Maintenance", texte: "Contrats annuels, entretien préventif et dépannage de votre parc." },
];

const domaines = ["Bureaux & tertiaire", "Commerces", "Hôtellerie-restauration", "Santé / ERP"];
---

<Base
  title="Climatisation tertiaire VRV Marseille et Paris"
  description="Bathermex, climatisation tertiaire VRV/DRV : installation, supervision (GTB) et maintenance. Un interlocuteur unique en PACA et Île-de-France."
>
  <!-- ============ HERO PORTAIL ============ -->
  <section class="relative overflow-hidden bg-ink text-fog">
    {heroImages.accueil && (
      <img src={heroImages.accueil} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover" />
    )}
    {heroImages.accueil && <div class="absolute inset-0 bg-ink/75"></div>}
    <div class="relative mx-auto max-w-6xl px-5 py-24 md:py-32">
      <p class="eyebrow !text-copper-bright">Climatisation tertiaire · VRV/DRV · Maintenance · GTB · PACA &amp; Île-de-France</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-semibold leading-[1.08] text-white md:text-6xl">
        Installer, superviser et maintenir vos installations CVC.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-fog/80">
        Un interlocuteur unique pour vos installations de climatisation tertiaire, en PACA et en Île-de-France.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/solutions-cvc" class="btn btn-light">Solutions CVC</a>
        <a href="/solutions-gtb" class="btn btn-ghost !border-white/25 !text-white hover:!border-copper">Solutions GTB</a>
        <a href="/maintenance" class="btn btn-ghost !border-white/25 !text-white hover:!border-copper">Maintenance</a>
      </div>
      <div class="mt-8">
        <a href="/contact" class="text-sm font-medium text-copper-bright underline underline-offset-4">Demander un devis →</a>
      </div>
    </div>
  </section>

  <!-- ============ LOGOS CLIENTS (conditionnel) ============ -->
  {logosClients.length > 0 && (
    <section class="border-b border-mist bg-paper">
      <div class="mx-auto max-w-6xl px-5 py-12">
        <p class="eyebrow text-center">Ils nous font confiance</p>
        <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
          {logosClients.map((l) => (
            <li><img src={l.src} alt={l.alt} height="36" class="h-9 w-auto opacity-80" loading="lazy" /></li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ============ NOS SOLUTIONS (3 cartes) ============ -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="copper-rule mb-5"></div>
    <h2 class="text-3xl font-semibold text-ink">Nos solutions</h2>
    <div class="mt-9 grid gap-5 md:grid-cols-3">
      {solutions.map((s) => (
        <a href={s.href} class="card block p-7 transition-shadow hover:shadow-[0_1px_0_#bd5a17]">
          <h3 class="font-display text-xl font-semibold text-ink">{s.titre}</h3>
          <p class="mt-2 text-slate">{s.texte}</p>
          <span class="link-copper mt-4 inline-block text-sm font-medium">Découvrir →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ============ DOMAINES (décision E) ============ -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Nos domaines d'intervention</h2>
      <ul class="mt-6 flex flex-wrap gap-2">
        {domaines.map((d) => (
          <li class="rounded-full border border-mist bg-fog px-4 py-1.5 text-sm text-slate">{d}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ RÉALISATIONS (aperçu) ============ -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="copper-rule mb-5"></div>
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="text-3xl font-semibold text-ink">Réalisations</h2>
        <p class="mt-3 max-w-2xl text-slate">La preuve par les chantiers : contexte, solution mise en œuvre, résultat.</p>
      </div>
      <a href="/realisations" class="link-copper text-sm font-medium">Toutes les réalisations →</a>
    </div>
    <div class="mt-9 grid gap-5 md:grid-cols-3">
      {apercuAccueil.map((r) => (
        <article class="card overflow-hidden">
          {r.image
            ? <img src={r.image} alt={r.titre} width="640" height="480" class="aspect-[4/3] w-full border-b border-mist object-cover" loading="lazy" />
            : <div class="flex aspect-[4/3] items-center justify-center border-b border-mist bg-fog text-xs font-medium uppercase tracking-wider text-slate/60">Photo chantier</div>}
          <div class="p-6">
            <span class="eyebrow text-[0.7rem]">{r.typologie}</span>
            <h3 class="mt-2 font-display text-lg font-semibold text-ink">{r.titre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate">{r.contexte}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ============ SOCIÉTÉ ============ -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="grid gap-10 md:grid-cols-[1.4fr_1fr]">
        <div class="space-y-4 leading-relaxed text-slate">
          <div class="copper-rule mb-2"></div>
          <h2 class="text-3xl font-semibold text-ink">Bathermex, de Marseille à Paris</h2>
          <p>Spécialistes de la climatisation tertiaire à détente directe (VRV/DRV), nous installons, supervisons et entretenons vos équipements sur deux implantations complémentaires : Allauch (13) et Paris / Île-de-France.</p>
          <p>Nous intervenons en direct, en sous-traitance déclarée pour des entreprises générales, et sur les marchés publics.</p>
          <a href="/a-propos" class="link-copper inline-block text-sm font-medium">En savoir plus →</a>
        </div>
        <aside class="card p-6">
          <h3 class="eyebrow mb-3">Nos engagements</h3>
          <ul class="space-y-2 text-sm text-slate">
            <li class="flex gap-2"><span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-copper"></span>Garantie décennale sur nos ouvrages (art. 1792)</li>
            <li class="flex gap-2"><span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-copper"></span>Deux implantations : PACA et Île-de-France</li>
            <li class="flex gap-2"><span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-copper"></span>Suivi et conseil dans la durée</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <CTA />
</Base>
