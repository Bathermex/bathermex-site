---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
import { faq, heroImages } from "../data/content";
---

<Base title="À propos" description="Bathermex, entreprise spécialisée en climatisation tertiaire VRV / DRV, implantée à Allauch (13) et en Île-de-France.">
  <PageHero
    image={heroImages.aPropos}
    eyebrow="L'entreprise"
    title="Spécialistes de la climatisation tertiaire"
    intro="Bathermex conçoit, installe et entretient des systèmes VRV / DRV pour les bâtiments tertiaires, sur deux implantations complémentaires."
  />

  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr]">
      <div class="space-y-5 leading-relaxed text-slate">
        <p class="text-lg text-ink">
          〔À COMPLÉTER : présentation de Bathermex〕 — quelques lignes sur l'histoire de l'entreprise,
          son positionnement sur le tertiaire et ce qui la distingue.
        </p>
        <p>
          Notre métier : la détente directe à débit de réfrigérant variable (VRV / DRV), pour les bureaux,
          commerces, ERP et bâtiments tertiaires, en neuf comme en rénovation. Nous intervenons en direct,
          en sous-traitance déclarée pour des entreprises générales, et sur les marchés publics.
        </p>
        <p>
          〔À COMPLÉTER : un mot sur l'équipe et son savoir-faire〕 — taille, compétences, certifications
          ou attestations détenues (à indiquer uniquement si elles sont avérées et vérifiables).
        </p>
      </div>

      <aside class="space-y-5">
        <div class="card p-6">
          <h2 class="eyebrow mb-3">Nos implantations</h2>
          <ul class="space-y-3 text-sm text-slate">
            <li><span class="font-semibold text-ink">Allauch (13190)</span><br/>Couverture PACA — Bouches-du-Rhône et départements voisins.</li>
            <li><span class="font-semibold text-ink">Paris / Île-de-France</span><br/>Chantiers tertiaires à Paris et en région parisienne.</li>
          </ul>
        </div>
        <div class="card p-6">
          <h2 class="eyebrow mb-3">Nos engagements</h2>
          <ul class="space-y-2 text-sm text-slate">
            <li class="flex gap-2"><span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-copper"></span>Garantie décennale sur nos ouvrages</li>
            <li class="flex gap-2"><span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-copper"></span>Personnel attesté pour les fluides frigorigènes</li>
            <li class="flex gap-2"><span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-copper"></span>Suivi et conseil dans la durée</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-paper">
    <div class="mx-auto max-w-4xl px-5 py-16">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Questions fréquentes</h2>
      <div class="mt-8 divide-y divide-mist border-y border-mist">
        {faq.map((f) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-medium text-ink">
              {f.q}
              <span class="text-copper transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-3 leading-relaxed text-slate">{f.r}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Base>
