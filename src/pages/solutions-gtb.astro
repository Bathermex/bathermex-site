---
// ============================================================
// /solutions-gtb — S1 (Lot S). Page "hors menu".
// ⚠️⚠️ CONTENU NON VALIDÉ DIRECTION — NE PAS MERGER / DÉPLOYER AVANT GO.
// Engagement commercial direct, ZÉRO contenu existant repris.
// Rédigé sur le PÉRIMÈTRE confirmé direction (10/07) : supervision à
// distance · télémaintenance · intégration complète. Aucune marque ni
// protocole nommé (à compléter par la direction). FAQ laissée vide
// tant que les questions/réponses ne sont pas validées.
// ============================================================
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";

const domaines = ["Bureaux & tertiaire", "Commerces", "Hôtellerie-restauration", "Santé / ERP"];

// ✏️ à valider direction
const offre = [
  { titre: "Supervision à distance", texte: "Nous suivons en continu le fonctionnement de vos installations : températures, états de marche, alarmes techniques. Les dérives sont détectées avant qu'elles ne deviennent des pannes, et vos consommations restent sous contrôle." },
  { titre: "Télémaintenance", texte: "La plupart des réglages et des diagnostics se font à distance, sans déplacement : une réaction plus rapide, moins d'interruptions pour vos équipes, une intervention sur site déclenchée seulement quand elle est nécessaire." },
  { titre: "Intégration complète", texte: "Nous raccordons vos équipements — même de marques différentes — à une supervision unique et lisible. Vous pilotez l'ensemble depuis une seule interface." },
];

const methode = [
  { n: "01", titre: "Audit", texte: "Point sur vos équipements et vos besoins de pilotage." },
  { n: "02", titre: "Intégration", texte: "Mise en supervision des équipements, y compris l'existant." },
  { n: "03", titre: "Mise en service", texte: "Tableau de bord, seuils d'alarme, remontée des informations." },
  { n: "04", titre: "Suivi", texte: "Supervision continue, interventions à distance ou sur site." },
];

// ✏️ adapté du contenu fourni par Brice — réécrit (original), "GTB Light" retiré,
// chiffre "30%" et "nos clients observent" retirés (promesse de résultat invérifiable).
const avantages = [
  { titre: "Économies d'énergie", points: [
    "Réduction des coûts : une gestion optimisée de l'énergie permet de réduire les factures énergétiques du bâtiment.",
    "Utilisation rationnelle des ressources : la supervision technique favorise un usage plus efficace des équipements de votre bâtiment.",
  ] },
  { titre: "Contrôle et transparence", points: [
    "Gestion centralisée : un tableau de bord unique offre une vision claire et complète de la performance de vos installations.",
    "Décisions basées sur les données : des informations précises et en temps réel rendent le pilotage plus rapide et plus efficace.",
  ] },
  { titre: "Conformité aux normes", points: [
    "Respect des exigences légales : nos solutions visent à répondre aux obligations réglementaires, notamment le décret tertiaire et le décret BACS.",
    "Préparation pour l'avenir : des systèmes pensés pour s'adapter aux évolutions réglementaires à venir.",
  ] },
  { titre: "Maintenance préventive", points: [
    "Une surveillance continue permet d'identifier et de résoudre les anomalies avant qu'elles ne deviennent critiques, réduisant les temps d'arrêt et les coûts de maintenance.",
  ] },
];

// ⬜ FAQ à écrire/valider direction — laissée vide volontairement (rien de non validé ne s'affiche)
// ✏️ FAQ Lot SEO item 3 — À VALIDER DIRECTION avant merge (comme le reste de la page)
const faqGtb: { q: string; r: string }[] = [
  {
    q: "Qu'est-ce qu'une GTB ?",
    r: "La GTB (gestion technique du bâtiment) est le système qui centralise le pilotage des équipements techniques d'un bâtiment — chauffage, climatisation, ventilation — sur une interface unique. Elle permet de suivre les températures, les états de marche et les alarmes, de programmer les horaires et de détecter les dérives de consommation.",
  },
  {
    q: "Mon bâtiment est-il concerné par le décret BACS ?",
    r: "Le décret BACS s'applique aux bâtiments tertiaires équipés de systèmes de chauffage ou de climatisation, avec un calendrier selon la puissance : les systèmes de plus de 290 kW sont concernés depuis le 1er janvier 2025, et l'échéance pour les puissances comprises entre 70 et 290 kW est fixée au 1er janvier 2030. Une exemption est possible lorsque l'étude démontre un retour sur investissement supérieur à dix ans. Un audit de votre site permet de trancher votre cas précis.",
  },
  {
    q: "Peut-on raccorder des équipements existants, de marques différentes ?",
    r: "Oui, c'est le cœur de l'intégration complète : nous raccordons vos équipements existants, même hétérogènes, à une supervision unique. Il n'est pas nécessaire de remplacer votre parc pour le piloter.",
  },
  {
    q: "La télémaintenance remplace-t-elle les visites sur site ?",
    r: "Elle les complète. La majorité des diagnostics et des réglages se font à distance, ce qui accélère la réaction et réduit les déplacements. Les interventions sur site restent nécessaires pour les opérations physiques — et sont déclenchées à bon escient, sur la base de ce que la supervision a déjà identifié.",
  },
];
const faqSchemaGtb = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqGtb.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.r },
  })),
};
---

<Base
  title="GTB, supervision & télémaintenance CVC · Marseille & Paris"
  description="GTB et télémaintenance de vos installations de climatisation et chauffage : supervision à distance, intégration complète, conformité décret BACS. Marseille, PACA et Île-de-France."
>
  <PageHero
    image="/photos/hero-gtb.webp"
    imageAlt="Écran de supervision GTB affichant le plan technique d'un bâtiment"
    eyebrow="Solutions GTB"
    title="GTB, supervision et télémaintenance de vos installations CVC à Marseille et en Île-de-France"
    intro="Gardez le contrôle de votre confort et de vos consommations, à distance : supervision, télémaintenance et intégration de vos équipements de climatisation et de chauffage."
  />

  <!-- Qu'est-ce que la GTB ? (bloc éducatif SEO, ✏️ adapté du contenu fourni par Brice — réécrit pour éviter le contenu dupliqué ; concurrent + lien externe retirés) -->
  <section class="mx-auto max-w-3xl px-5 pt-16">
    <p class="eyebrow">Intégrateur GTB — gestion énergétique optimale de vos espaces</p>
    <div class="copper-rule my-5"></div>
    <h2 class="font-display text-3xl font-semibold text-ink">Qu'est-ce que la GTB ?</h2>
    <div class="mt-6 space-y-4 leading-relaxed text-slate">
      <p>La <strong>GTB</strong> (Gestion Technique du Bâtiment) permet de superviser et d'optimiser les systèmes techniques d'un bâtiment : éclairage, chauffage, ventilation, climatisation et l'ensemble des postes essentiels à un bâtiment fonctionnel et confortable.</p>
      <p>Son évolution s'inscrit dans une démarche de développement durable : elle réduit les coûts d'exploitation, optimise l'usage des ressources et favorise la sobriété énergétique en limitant les consommations inutiles.</p>
      <p>Aujourd'hui, la GTB est au cœur des bâtiments intelligents, où efficacité, confort et sécurité se conjuguent pour des espaces de travail mieux maîtrisés.</p>
      <p>Bathermex intègre cette technologie dans ses <a href="/solutions-cvc" class="font-medium text-copper underline-offset-2 hover:underline">solutions tertiaires</a> et se positionne comme <strong>intégrateur GTB</strong>, de la supervision à distance à l'intégration complète de vos équipements.</p>
    </div>
  </section>

  <!-- L'offre (3 blocs, ✏️ à valider direction) -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="grid gap-5 md:grid-cols-3">
      {offre.map((o, i) => (
        <article class="card p-7">
          <div class="font-display text-2xl font-semibold text-copper">{String(i + 1).padStart(2, "0")}</div>
          <h2 class="mt-3 font-display text-xl font-semibold text-ink">{o.titre}</h2>
          <p class="mt-2 leading-relaxed text-slate">{o.texte}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Pourquoi choisir Bathermex ? (4 bénéfices GTB, ✏️ adapté/réécrit — voir note dans le frontmatter) -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="copper-rule mb-5"></div>
      <h2 class="font-display text-3xl font-semibold text-ink">Pourquoi choisir Bathermex comme intégrateur GTB ?</h2>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {avantages.map((a) => (
          <article class="card p-6">
            <h3 class="font-display text-lg font-semibold text-ink">{a.titre}</h3>
            <ul class="mt-4 space-y-3">
              {a.points.map((p) => (
                <li class="flex gap-2.5 text-sm leading-relaxed text-slate">
                  <span class="mt-0.5 shrink-0 font-semibold text-copper" aria-hidden="true">✓</span>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Bandeau photo -->
  <section class="mx-auto max-w-6xl px-5 pb-4">
    <figure>
      <img src="/photos/inpage-gtb.webp" alt="Armoire de commande à écran tactile pour la supervision d'installations CVC" width="1200" height="520" loading="lazy" class="aspect-[16/7] w-full rounded-xl object-cover shadow-sm" />
      <figcaption class="mt-3 text-center text-sm text-slate">Supervision technique par écran tactile — pilotage et télémaintenance à distance.</figcaption>
    </figure>
  </section>

  <!-- Pour qui (décision E actée) -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Pour qui</h2>
      <ul class="mt-6 flex flex-wrap gap-2">
        {domaines.map((d) => (
          <li class="rounded-full border border-mist bg-fog px-4 py-1.5 text-sm text-slate">{d}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Schéma supervision GTB (fourni par Brice, droits confirmés — marque tierce retirée) — centré, taille native -->
  <section class="mx-auto max-w-6xl px-5 pt-4 pb-12">
    <figure class="mx-auto max-w-xl">
      <img src="/photos/schema-gtb.webp" alt="Schéma d'une supervision GTB : un poste central pilote la ventilation, le chauffage, la climatisation, l'éclairage, le contrôle d'accès, l'alarme, la sécurité incendie et les meubles réfrigérés" width="750" height="636" loading="lazy" class="mx-auto w-full rounded-xl border border-mist bg-white p-3 shadow-sm" />
      <figcaption class="mt-3 text-center text-sm text-slate">La GTB centralise le pilotage des équipements techniques du bâtiment sur une seule supervision.</figcaption>
    </figure>
  </section>

  <!-- Comment on travaille -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="copper-rule mb-5"></div>
    <h2 class="max-w-xl text-3xl font-semibold text-ink">Comment on travaille</h2>
    <ol class="mt-12 grid gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {methode.map((m) => (
        <li class="relative pr-6">
          <span class="font-display text-sm font-semibold text-copper">{m.n}</span>
          <h3 class="mt-2 font-display text-lg font-semibold text-ink">{m.titre}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate">{m.texte}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- FAQ : conditionnel, vide tant que non validé direction -->
  {faqGtb.length > 0 && (
    <section class="bg-paper">
      <div class="mx-auto max-w-4xl px-5 py-16">
        <div class="copper-rule mb-5"></div>
        <h2 class="text-3xl font-semibold text-ink">Questions fréquentes</h2>
        <div class="mt-8 divide-y divide-mist border-y border-mist">
          {faqGtb.map((f) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-medium text-ink">
                {f.q}
                <span class="text-copper transition-transform group-open:rotate-45" aria-hidden="true">+</span>
              </summary>
              <p class="mt-3 leading-relaxed text-slate">{f.r}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Décret BACS — Lot SEO item 3 (sources : décrets 2020-887, 2023-259, 2025-1343) -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="copper-rule mb-5"></div>
    <h2 class="max-w-3xl text-3xl font-semibold text-ink">Décret BACS : ce que la réglementation impose</h2>
    <p class="mt-4 max-w-3xl leading-relaxed text-slate">
      Le décret BACS rend progressivement obligatoire l'installation d'un système d'automatisation et de contrôle — une GTB — dans les bâtiments tertiaires équipés de systèmes de chauffage ou de climatisation. Les bâtiments dont les systèmes dépassent 290 kW sont concernés depuis le 1<sup>er</sup> janvier 2025 ; pour les puissances comprises entre 70 et 290 kW, l'échéance est fixée au 1<sup>er</sup> janvier 2030. Une exemption reste possible lorsque l'étude démontre un temps de retour sur investissement supérieur à dix ans.
    </p>
    <p class="mt-3 max-w-3xl leading-relaxed text-slate">
      Notre rôle : auditer votre site, déterminer si votre bâtiment est concerné et à quelle échéance, puis mettre en place la solution proportionnée — de la supervision simple à l'intégration complète. Le pilotage rejoint ensuite vos <a href="/maintenance/" class="font-semibold text-copper hover:underline">obligations d'exploitation et de maintenance</a>.
    </p>
  </section>

  <!-- Où nous intervenons — Lot SEO item 3 (aligné zones fiche Google) -->
  <section class="bg-paper">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="copper-rule mb-5"></div>
      <h2 class="text-3xl font-semibold text-ink">Où nous intervenons</h2>
      <p class="mt-4 max-w-3xl leading-relaxed text-slate">
        Nous déployons et supervisons des installations sur Marseille, Allauch, Aubagne, Aix-en-Provence, Marignane, Salon-de-Provence, l'ensemble des Bouches-du-Rhône et la région PACA, ainsi que sur Paris et l'Île-de-France. La supervision à distance couvre les deux régions depuis une même plateforme.
      </p>
    </div>
  </section>

  <CTA title="Un besoin de supervision ?" text="Parlons de vos installations et de vos objectifs de pilotage à distance." />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchemaGtb)} />
</Base>
