---
import Base from "../layouts/Base.astro";
---

<Base title="Message envoyé" description="Votre message a bien été envoyé à Bathermex.">
  <section class="mx-auto max-w-2xl px-5 py-28 text-center">
    <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-copper-50">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#bd5a17" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h1 class="text-3xl font-semibold text-ink">Message bien reçu</h1>
    <p class="mt-4 leading-relaxed text-slate">
      Merci pour votre demande. Nous revenons vers vous dans les meilleurs délais.
    </p>
    <a href="/" class="btn btn-primary mt-8">Retour à l'accueil</a>
  </section>
</Base>
