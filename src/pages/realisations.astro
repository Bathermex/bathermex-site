---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";
import { realisations, realisationExempleRedige, realisationsEntretien, heroImages } from "../data/content";
// Grille uniforme : les 3 réalisations + le chantier détaillé = 4 fiches (2x2, aucun trou)
const poses = [...realisations, realisationExempleRedige];
// Intercalage pose / entretien : pose, entretien, pose, entretien, ...
const items = [];
const _n = Math.max(poses.length, realisationsEntretien.length);
for (let i = 0; i < _n; i++) {
  if (poses[i]) items.push(poses[i]);
  if (realisationsEntretien[i]) items.push(realisationsEntretien[i]);
}
---

<Base title="Réalisations" description="Chantiers de climatisation tertiaire VRV / DRV réalisés par Bathermex : contexte, solution et résultat.">
  <PageHero
    image={heroImages.realisations}
    eyebrow="La preuve par les chantiers"
    title="Réalisations"
    intro="Nos chantiers, présentés simplement : le contexte de départ, la solution mise en œuvre, le résultat pour l'exploitant."
  />

  <section class="mx-auto max-w-6xl px-5 py-16">
    <figure class="mb-12">
      <img src="/photos/realisations-installations.webp" alt="Installations Bathermex : réseaux aérauliques, groupes extérieurs et régulation en local technique" loading="lazy" class="w-full rounded-xl border border-mist" />
      <figcaption class="mt-3 text-sm text-slate">Aperçu de nos installations en VRV / DRV et aéraulique.</figcaption>
    </figure>

    <div class="grid gap-6 md:grid-cols-2">
      {items.map((r) => (
        <article class="card flex flex-col overflow-hidden">
          {r.image
            ? <img src={r.image} alt={r.titre} width="960" height="540" class="aspect-[16/9] w-full border-b border-mist object-cover" loading="lazy" />
            : <div class="flex aspect-[16/9] items-center justify-center border-b border-mist bg-fog text-xs font-medium uppercase tracking-wider text-slate/60">Photo chantier</div>}
          <div class="flex flex-1 flex-col p-7">
            <span class="eyebrow text-[0.7rem]">{r.typologie}{r.lieu ? ` · ${r.lieu}` : ""}</span>
            <h2 class="mt-2 font-display text-xl font-semibold text-ink">{r.titre}</h2>
            {r.entretien
              ? <p class="mt-4 text-sm leading-relaxed text-slate">{r.phrase}</p>
              : <dl class="mt-4 space-y-3 text-sm leading-relaxed">
                  <div><dt class="font-semibold text-petrol">Contexte</dt><dd class="text-slate">{r.contexte}</dd></div>
                  <div><dt class="font-semibold text-petrol">Solution</dt><dd class="text-slate">{r.solution}</dd></div>
                  <div><dt class="font-semibold text-petrol">Résultat</dt><dd class="text-slate">{r.resultat}</dd></div>
                </dl>}
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTA />
</Base>
